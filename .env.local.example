# Rename this file to .env.local and fill in your Firebase project credentials
# Get these from Firebase Console > Project Settings > General > Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# School info (used across the portal & website)
NEXT_PUBLIC_SCHOOL_NAME="Jidda Standard Academy"
NEXT_PUBLIC_CURRENT_SESSION="2025/2026"
NEXT_PUBLIC_CURRENT_TERM="First Term"

# Server-side only — used by app/api/auth/* routes + middleware to verify sessions.
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Paste the ENTIRE JSON file contents here as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=
